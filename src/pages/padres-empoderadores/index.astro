---
import LayoutPadres from '../../layouts/LayoutPadres.astro';
import NavbarPadres from '../../components/NavbarPadres.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api-courses.coexpace.org';
// TODO: replace with real course_id from backend once assigned
const courseId = Number(import.meta.env.PUBLIC_PADRES_COURSE_ID || 0);

const modules = [
  {
    n: 1,
    title: "Lo que NO funciona",
    description: "Errores comunes que empeoran el problema.",
    bullets: [
      "Los consejos tradicionales (\"defiéndete\", \"ignóralo\") que fallan",
      "Frases bien intencionadas que hacen sentir al niño peor",
      "Cómo evitar el \"autobullying\" — cuando tu hij@ se ataca a sí mismo",
    ],
    thumb: "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M1L1.png",
  },
  {
    n: 2,
    title: "Cómo intervenir correctamente",
    description: "El rol del adulto según el método EPI.",
    bullets: [
      "La importancia de tu presencia adulta — más allá de dar consejos",
      "Escuchar sin juzgar: lo que más ayuda según los propios niños",
      "Cómo dar seguimiento sin invadir ni abandonar",
    ],
    thumb: "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M2L1.png",
  },
  {
    n: 3,
    title: "Estrategias que SÍ funcionan",
    description: "Herramientas reales y aplicables hoy.",
    bullets: [
      "Cómo empoderar a tu hij@ desde adentro",
      "Respuestas concretas frente al bullying",
      "Fortalecer su autoestima con acciones diarias",
    ],
    thumb: "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M3L1.png",
  },
];

const lessonThumbs = [
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M0Intro.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M1L1.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M1L2.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M1L3.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M1L4.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M1L5.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M2L1.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M2L2.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M2L3.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M2L4.png",
  "/images/padres/CXP_LRNG_CPE_THUMBNAIL_YT_M3L1.png",
];

const faqs = [
  { q: "¿Es solo para casos graves de bullying?", a: "No. El método funciona desde situaciones leves hasta complejas. Es útil también como prevención." },
  { q: "¿Puedo aplicarlo aunque mi hij@ no hable mucho?", a: "Sí. Parte del curso está dedicado a cómo generar apertura emocional sin forzar la conversación." },
  { q: "¿Sirve también para adolescentes?", a: "Sí. El enfoque es aplicable a distintas edades — se adapta al lenguaje y las dinámicas de cada etapa." },
  { q: "¿Necesito conocimientos previos?", a: "Ninguno. El curso está diseñado para cualquier padre o cuidador, sin formación técnica." },
  { q: "¿Cuánto tiempo tengo acceso?", a: "Acceso de por vida. Puedes volver al contenido cada vez que necesites revisitar una herramienta." },
];
---

<LayoutPadres title="Padres Empoderadores — Cómo ayudar a tu hij@ frente al bullying | Alejandra Schatzky">
  <NavbarPadres />

  <!-- Language Floater -->
  <a href="/en" title="Switch to English" aria-label="Switch to English" style="position:fixed;right:24px;bottom:32px;z-index:99999;width:50px;height:50px;border-radius:50%;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border:1px solid rgba(0,0,0,0.10);box-shadow:0 4px 20px rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;overflow:hidden;transition:transform 0.25s ease,box-shadow 0.25s ease;text-decoration:none;" onmouseenter="this.style.transform='scale(1.12) translateY(-3px)';this.style.boxShadow='0 8px 30px rgba(0,0,0,0.2)';" onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.15)';">
    <img src="https://flagcdn.com/w80/us.png" alt="English" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;" />
  </a>

  <main>

    <!-- ===== HERO ===== -->
    <section class="hero-pe" id="hero">
      <div class="container position-relative z-2 reveal text-center">
        <span class="badge-pe">Curso para padres · Método EPI</span>
        <h1 class="hero-title-pe">¿Tu hij@ está sufriendo <em class="text-rust">bullying</em> y no sabes cómo ayudarle?</h1>
        <p class="hero-sub-pe">Aprende qué decir, qué hacer y cómo actuar para proteger a tu hij@ sin empeorar la situación. Un programa práctico basado en el método EPI, con herramientas reales para padres.</p>
        <div class="d-flex flex-column align-items-center">
          <a href="#checkout" class="btn-gold mb-4">Acceder al Curso</a>
          <p class="small" style="color:#6b5d48;letter-spacing:1px;"><span class="text-gold">★</span> Más de 20 años de experiencia con familias</p>
        </div>
      </div>
    </section>

    <!-- ===== COVER VISUAL — full-width hero image ===== -->
    <section class="cover-hero-pe reveal">
      <img src="/images/padres/COVER_Padres.png" alt="Padres Empoderadores con Alejandra Schatzky" />
    </section>

    <!-- ===== SOCIAL PROOF / STATS ===== -->
    <section class="py-5" style="background:transparent;">
      <div class="container py-4 reveal">
        <div class="row align-items-center">
          <div class="col-lg-5 mb-5 mb-lg-0">
            <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:400;color:#2a2317;">Un método probado<br><em class="text-gold">para padres reales</em></h2>
            <div style="width:40px;height:1px;background:#d4a235;margin:1.2rem 0 1.5rem;"></div>
            <p style="color:#6b5d48;font-size:1.1rem;line-height:1.8;font-weight:300;">No es teoría. Es el método EPI aplicado durante más de 20 años en familias, escuelas y empresas — traducido a herramientas que funcionan en tu casa.</p>
          </div>
          <div class="col-lg-7">
            <div class="row g-4 text-center">
              {[["7","Videos","prácticos paso a paso"],["3","Módulos","del método EPI"],["∞","Acceso","de por vida"]].map(([num,label,sub]) => (
                <div class="col-sm-4">
                  <div class="p-4 h-100 bg-white text-center" style="border:1px solid #e8dec9;border-top:2.5px solid #d4a235;border-radius:6px;box-shadow:0 2px 12px rgba(42,35,23,0.05);">
                    <span class="d-block" style="font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:300;line-height:1;margin-bottom:0.5rem;color:#2a2317;">{num}</span>
                    <strong class="d-block text-uppercase" style="font-family:'Inter',sans-serif;font-size:0.72rem;letter-spacing:2px;color:#d4a235;margin-bottom:0.3rem;">{label}</strong>
                    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#8f7f65;font-style:italic;">{sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEM / EMOTIONAL ===== -->
    <section class="py-5" style="background:linear-gradient(160deg,#f5ebdc 0%,#f0e3cc 100%);">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-rust fw-bold text-uppercase small" style="letter-spacing:2px;">El Problema</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#2a2317;margin-top:1rem;">Si tu hij@ llega triste, callado<br/>o con miedo…</h2>
          <div style="width:40px;height:1px;background:#d4a235;margin:1.2rem auto 0;"></div>
        </div>

        <div class="reveal" style="margin-bottom:6rem;">
          <p class="text-center" style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-style:italic;color:#2a2317;line-height:1.6;margin:0 auto 3rem;max-width:720px;">No estás sol@. Muchos padres intentan ayudar con frases <strong>bien intencionadas</strong>…</p>

          <div class="row g-4 justify-content-center">
            {[
              { phrase: "Defiéndete", label: "Respuesta #1" },
              { phrase: "Ignóralo", label: "Respuesta #2" },
              { phrase: "Eso es normal", label: "Respuesta #3" },
            ].map((p, i) => (
              <div class="col-md-4 reveal" style={`transition-delay:${i * 100}ms`}>
                <div class="wrong-advice-pe">
                  <span class="wrong-tag-pe">{p.label}</span>
                  <div class="wrong-phrase-pe">"{p.phrase}"</div>
                  <div class="wrong-stamp-pe">No funciona</div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="row justify-content-center reveal">
          <div class="col-lg-10">
            <div class="impact-card-pe">
              <div class="impact-divider-pe">
                <span style="background:#fff;padding:0 1rem;font-family:'Cormorant Garamond',serif;font-style:italic;color:#a85a3f;font-size:1rem;letter-spacing:3px;text-transform:uppercase;">Y peor aún</span>
              </div>
              <p class="text-center" style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#2a2317;line-height:1.5;margin:2rem auto 2.5rem;max-width:650px;">Estos consejos pueden hacer que <strong>tu hij@ se sienta</strong>:</p>
              <div class="feelings-row-pe">
                {["Sol@", "Incomprendid@", "Culpable"].map((feeling, i) => (
                  <div class="feeling-chip-pe reveal" style={`transition-delay:${i * 100}ms`}>
                    <span class="feeling-text-pe">{feeling}</span>
                  </div>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== REALIDAD / EDUCATION ===== -->
    <section class="py-5" style="background:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-gold fw-bold text-uppercase small" style="letter-spacing:2px;">La Realidad</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:#2a2317;margin-top:1rem;">El problema no es que no quieras ayudar…</h2>
          <p style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-style:italic;color:#d4a235;margin-top:1rem;">es que <strong>nadie te enseñó cómo hacerlo</strong>.</p>
          <div style="width:40px;height:1px;background:#d4a235;margin:1.5rem auto 0;"></div>
        </div>

        <div class="row g-4 justify-content-center mt-4">
          <div class="col-md-6 reveal">
            <div class="p-5 h-100 bg-white" style="border-radius:0.75rem;border:1px solid #e8dec9;box-shadow:0 2px 12px rgba(42,35,23,0.05);">
              <span class="text-gold fs-3 mb-3 d-block" style="font-family:'Cormorant Garamond',serif;">01</span>
              <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:#2a2317;margin-bottom:1rem;">Los niños piden ayuda</h4>
              <p style="color:#6b5d48;font-weight:300;line-height:1.7;margin:0;">cuando <strong>ya no saben cómo resolver la situación solos</strong>. Si te habló, es porque confía — ahora depende de cómo respondes.</p>
            </div>
          </div>
          <div class="col-md-6 reveal" style="transition-delay:100ms;">
            <div class="p-5 h-100 bg-white" style="border-radius:0.75rem;border:1px solid #e8dec9;box-shadow:0 2px 12px rgba(42,35,23,0.05);">
              <span class="text-gold fs-3 mb-3 d-block" style="font-family:'Cormorant Garamond',serif;">02</span>
              <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:#2a2317;margin-bottom:1rem;">Lo que más ayuda</h4>
              <p style="color:#6b5d48;font-weight:300;line-height:1.7;margin:0;">no es intervenir — <strong>es escuchar correctamente</strong>. Y eso se aprende. Eso cambia todo.</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== LESSON THUMBNAILS SLIDER ===== -->
    <section class="py-5 my-3" style="background:#f5ebdc;">
      <div class="container py-5 reveal">
        <div class="text-center mb-5">
          <span class="text-gold text-uppercase small fw-bold" style="letter-spacing:2px;">El Programa</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#2a2317;margin-top:1rem;">11 lecciones prácticas</h2>
          <div style="width:40px;height:1px;background:#d4a235;margin:1.2rem auto 1rem;"></div>
          <p style="color:#6b5d48;font-weight:300;font-size:1.05rem;">Cada lección dura menos de 10 minutos. Puedes avanzar a tu ritmo.</p>
        </div>
        <div class="slider-wrapper-pe position-relative w-100">
          <div class="lesson-slider-pe d-flex" id="peSlider">
            {lessonThumbs.map((thumb, i) => (
              <div class="lesson-card-pe flex-shrink-0">
                <div class="lesson-thumb-wrap">
                  <img src={thumb} alt={`Lección ${i+1}`} loading="lazy" />
                </div>
              </div>
            ))}
          </div>
          <div class="slider-fade-pe right"></div>
          <div class="slider-fade-pe left"></div>
        </div>
      </div>
    </section>

    <!-- ===== MODULES ===== -->
    <section class="py-5" style="background:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-gold fw-bold text-uppercase small" style="letter-spacing:2px;">Estructura del Curso</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#2a2317;margin-top:1rem;">3 Módulos, un camino claro</h2>
          <div style="width:40px;height:1px;background:#d4a235;margin:1.2rem auto 0;"></div>
        </div>

        <div class="row g-4 justify-content-center">
          {modules.map((mod, i) => (
            <div class="col-md-4 reveal d-flex" style={`transition-delay:${i*100}ms`}>
              <div class="module-card-pe w-100 bg-white">
                <div class="module-thumb-pe">
                  <img src={mod.thumb} alt={mod.title} loading="lazy" />
                  <span class="module-number-pe">0{mod.n}</span>
                </div>
                <div class="module-body-pe p-4">
                  <span class="text-gold text-uppercase fw-bold d-block mb-2" style="letter-spacing:1.5px;font-size:0.72rem;">Módulo {mod.n}</span>
                  <h3 style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;font-weight:500;color:#2a2317;margin:0 0 0.75rem;line-height:1.2;">{mod.title}</h3>
                  <p style="color:#8f7f65;font-style:italic;font-size:0.9rem;margin:0 0 1.25rem;border-bottom:1px solid #f0e8d6;padding-bottom:1rem;">{mod.description}</p>
                  <ul class="list-unstyled mb-0">
                    {mod.bullets.map(b => (
                      <li style="color:#6b5d48;font-size:0.9rem;line-height:1.6;margin-bottom:0.6rem;display:flex;align-items:start;font-weight:300;"><span style="color:#d4a235;margin-right:10px;font-size:0.8rem;margin-top:4px;">✦</span>{b}</li>
                    ))}
                  </ul>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== BONUS TOOLS ===== -->
    <section class="py-5" style="background:linear-gradient(160deg,#fbf6ec 0%,#f5ebdc 100%);">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-rust fw-bold text-uppercase small" style="letter-spacing:2px;">Bonus Incluido</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#2a2317;margin-top:1rem;">Herramientas adicionales</h2>
          <div style="width:40px;height:1px;background:#d4a235;margin:1.2rem auto 0;"></div>
        </div>

        <div class="row g-4 justify-content-center">
          {[
            { title: "Manejo de emociones", text: "Herramientas concretas para padres e hijos frente al estrés y la frustración.", icon: "♡" },
            { title: "Identificar pensamientos negativos", text: "Cómo reconocer el diálogo interno dañino antes de que se instale.", icon: "◎" },
            { title: "Evitar el autobullying", text: "Muchas veces el niño se convierte en su propio agresor mental. Aquí aprendes a cortar ese ciclo.", icon: "✦" },
          ].map((b, i) => (
            <div class="col-md-4 reveal d-flex" style={`transition-delay:${i*100}ms`}>
              <div class="bonus-card-pe w-100 p-4 bg-white">
                <div style="font-size:2rem;color:#d4a235;line-height:1;margin-bottom:1rem;">{b.icon}</div>
                <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#2a2317;margin-bottom:0.75rem;">{b.title}</h4>
                <p style="color:#6b5d48;font-weight:300;margin:0;line-height:1.7;">{b.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== TRANSFORMATION ===== -->
    <section class="py-5" style="background:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-gold fw-bold text-uppercase small" style="letter-spacing:2px;">Lo que lograrás</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#2a2317;margin-top:1rem;">Tu Transformación</h2>
          <div style="width:40px;height:1px;background:#d4a235;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-0 reveal" style="border-radius:8px;overflow:hidden;background:#fff;box-shadow:0 4px 30px rgba(42,35,23,0.08);">
          <div class="col-md-6 transf-panel-pe" style="background:#f5ebdc;border-right:1px solid #e8dec9;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#8f7f65;margin-bottom:2rem;">Antes</h3>
            <ul class="list-unstyled">
              {["No sabes qué decir","Reaccionas mal o tarde","Tu hij@ se siente solo","Sientes que no puedes protegerl@"].map(item => (
                <li style="color:#8f7f65;font-size:1.05rem;margin-bottom:1.25rem;display:flex;align-items:start;font-weight:300;"><span style="opacity:0.6;margin-right:12px;">✕</span>{item}</li>
              ))}
            </ul>
          </div>
          <div class="col-md-6 transf-panel-pe" style="background:#fff;position:relative;">
            <div style="position:absolute;inset:0;background:radial-gradient(circle at top right,rgba(212,162,53,0.06),transparent);pointer-events:none;"></div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#d4a235;margin-bottom:2rem;position:relative;z-index:1;">Después</h3>
            <ul class="list-unstyled position-relative" style="z-index:1;">
              {["Sabes exactamente cómo actuar","Tu hij@ se siente escuchado","Construyes confianza real","Reduces el impacto del bullying"].map(item => (
                <li style="color:#2a2317;font-size:1.05rem;margin-bottom:1.25rem;display:flex;align-items:start;font-weight:400;"><span style="color:#d4a235;margin-right:12px;">✦</span>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== AUTHORITY / INSTRUCTOR ===== -->
    <section class="py-5" style="background:#fff;">
      <div class="container py-5 reveal">
        <div class="row align-items-center">
          <div class="col-lg-5 mb-5 mb-lg-0">
            <div style="aspect-ratio:1/1;background:linear-gradient(135deg,#f5ebdc 0%,#e8dec9 100%);border-radius:8px;box-shadow:0 8px 32px rgba(42,35,23,0.10);display:flex;align-items:center;justify-content:center;font-family:'Cormorant Garamond',serif;font-size:6rem;color:#d4a235;font-weight:300;">A·S</div>
            <p class="text-center mt-2" style="font-size:0.75rem;color:#8f7f65;letter-spacing:1px;">Foto próximamente</p>
          </div>
          <div class="col-lg-7 px-lg-5">
            <span class="text-gold text-uppercase small fw-bold" style="letter-spacing:2px;">Tu Guía</span>
            <h2 class="mb-4 mt-2" style="font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:400;color:#2a2317;">Alejandra Schatzky</h2>
            <div style="width:60px;height:1px;background:#d4a235;margin-bottom:1.5rem;"></div>
            <p style="font-size:1.1rem;color:#6b5d48;line-height:1.8;font-weight:300;margin-bottom:1.25rem;">Especialista en bullying con <strong>más de 20 años de experiencia</strong>. Creadora del método <strong>EPI</strong> — Educación, Prevención e Intervención — aplicado en familias, escuelas y empresas.</p>
            <p style="color:#6b5d48;line-height:1.8;font-weight:300;margin-bottom:2rem;">Experta en relaciones interpersonales y manejo emocional. Su enfoque combina rigor clínico con herramientas prácticas que cualquier padre puede aplicar desde hoy.</p>
            <p style="font-family:'Cormorant Garamond',serif;font-size:1.4rem;color:#2a2317;font-style:italic;border-left:2px solid #d4a235;padding-left:20px;">"Nadie merece ser maltratado. Y ningún padre debería sentirse sin herramientas para proteger a su hij@."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PRICING ===== -->
    <section class="py-5" id="checkout">
      <div class="container py-5 reveal">
        <div class="text-center mb-5 pb-2">
          <span class="text-gold text-uppercase small fw-bold" style="letter-spacing:2px;">Acceso</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#2a2317;margin-top:1rem;">Empieza hoy</h2>
        </div>
        <div class="row justify-content-center">
          <div class="col-lg-10">
            <div class="pricing-card-pe bg-white" style="border-radius:1rem;box-shadow:0 8px 40px rgba(42,35,23,0.1);border:1px solid rgba(212,162,53,0.25);overflow:hidden;">
              <!-- Left -->
              <div class="pricing-left-pe p-5 d-flex flex-column justify-content-center text-center" style="background:linear-gradient(135deg,rgba(251,246,236,0.9) 0%,rgba(212,162,53,0.08) 100%);">
