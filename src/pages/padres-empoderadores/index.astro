<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('peSlider');
    if (!slider) return;
    let isHovering = false;
    slider.addEventListener('mouseenter', () => { isHovering = true; });
    slider.addEventListener('mouseleave', () => { isHovering = false; });
    slider.addEventListener('touchstart', () => { isHovering = true; }, { passive: true });
    slider.addEventListener('touchend', () => { setTimeout(() => { isHovering = false; }, 2000); }, { passive: true });
    const cardWidth = () => window.innerWidth <= 768 ? 300 : 340;
    setInterval(() => {
      if (isHovering) return;
      if (slider.scrollLeft >= slider.scrollWidth - slider.clientWidth - 10) {
        slider.scrollTo({ left: 0, behavior: 'smooth' });
      } else {
        slider.scrollBy({ left: cardWidth(), behavior: 'smooth' });
      }
    }, 3500);
  });
</script>

<script define:vars={{ apiUrl, courseId }}>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.js-enroll-btn');
    const errorEl = document.querySelector('.js-enroll-error');

    buttons.forEach((btn) => {
      btn.addEventListener('click', async (e) => {
        e.preventDefault();
        if (btn.dataset.loading === '1') return;

        if (!courseId || courseId === 0) {
          if (errorEl) {
            errorEl.textContent = 'El curso aún no está disponible. Vuelve pronto.';
            errorEl.style.display = 'block';
          }
          return;
        }

        if (errorEl) { errorEl.style.display = 'none'; errorEl.textContent = ''; }
        btn.dataset.loading = '1';
        btn.style.pointerEvents = 'none';
        btn.style.opacity = '0.75';
        btn.innerHTML = 'Procesando…';

        try {
          const res = await fetch(`${apiUrl}/api/payments/guest-checkout-session`, {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ course_id: courseId }),
          });
          if (!res.ok) throw new Error(`HTTP ${res.status}`);
          const data = await res.json();
          if (!data.checkout_url) throw new Error('Respuesta inválida del servidor.');
          window.location.href = data.checkout_url;
        } catch (err) {
          console.error('[enroll]', err);
          btn.dataset.loading = '';
          btn.style.pointerEvents = '';
          btn.style.opacity = '';
          btn.innerHTML = btn.dataset.originalText || 'Acceder al Curso →';
          if (errorEl) {
            errorEl.textContent = 'No pudimos iniciar el pago. Intenta de nuevo en unos segundos.';
            errorEl.style.display = 'block';
          }
        }
      });
    });
  });
</script>
