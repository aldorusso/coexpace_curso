    }
    .hero-title-en { font-size: 2.5rem; margin: 1rem 0 0.75rem; }
    .hero-sub-en { font-size: 0.95rem; margin-bottom: 2rem; padding: 0 0.5rem; }
    .badge-pill-en { font-size: 0.65rem; letter-spacing: 2px; }

    /* Sections — consistent vertical rhythm */
