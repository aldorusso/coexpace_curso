---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Hero from '../components/Hero.astro';
import SocialProof from '../components/SocialProof.astro';
import ProblemSolution from '../components/ProblemSolution.astro';
import Transformation from '../components/Transformation.astro';
import Testimonials from '../components/Testimonials.astro';
import Program from '../components/Program.astro';
import Instructor from '../components/Instructor.astro';
import Bonuses from '../components/Bonuses.astro';
import Steps from '../components/Steps.astro';
import Pricing from '../components/Pricing.astro';
import FAQ from '../components/FAQ.astro';
import LanguageFloater from '../components/LanguageFloater.astro';
---

<Layout title="Meditación y Mindfulness para la Vida Diaria | COEXPACE">
    <Navbar />
    <LanguageFloater />
	<main>
		<Hero />
		<SocialProof />
        <Testimonials />
		<ProblemSolution />
		<Transformation />
        <Program />
        <Instructor />
        <Bonuses />
        <Steps />
        <Pricing />
    <footer class="bg-white py-5 border-top" style="border-color: rgba(217, 119, 6, 0.1) !important;">
       <div class="container py-4">
         <div class="row gy-5">
           <!-- About Column -->
           <div class="col-lg-5 col-md-12 pe-lg-5 reveal">
             <h4 class="mb-3 text-dark text-uppercase tracking-wide" style="font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; letter-spacing: 4px;">COEXPACE</h4>
             <div class="mt-2 mb-4" style="width: 40px; height: 1px; background-color: #d97706;"></div>
             <p class="text-muted fw-light lh-lg mb-3" style="font-size: 0.95rem;">
               COEXPACE es una iniciativa global que activa la empatía, el coraje moral y la convivencia a través del storytelling inmersivo, la educación y la acción cívica.
             </p>
             <p class="text-muted fw-light lh-lg mb-0" style="font-size: 0.95rem;">
               Creamos experiencias transformadoras que desafían supuestos, generan diálogo crítico y ayudan a las personas a actuar con integridad.
             </p>
           </div>

           <!-- Links Column -->
           <div class="col-lg-3 col-md-6 reveal" style="transition-delay: 100ms">
             <h5 class="mb-4 text-dark text-uppercase tracking-wide" style="font-size: 0.9rem; letter-spacing: 2px;">Explorar</h5>
             <ul class="list-unstyled d-flex flex-column gap-3 mb-0">
               <li><a href="https://coexpace.org/" class="text-muted text-decoration-none fw-light footer-link">Inicio</a></li>
               <li><a href="https://coexpace.org/about-us" class="text-muted text-decoration-none fw-light footer-link">Sobre Nosotros</a></li>
               <li><a href="https://coexpace.org/coexpace-center" class="text-muted text-decoration-none fw-light footer-link">COEXPACE Center</a></li>
               <li><a href="https://coexpace.org/events" class="text-muted text-decoration-none fw-light footer-link">Cumbres y Exposiciones</a></li>
             </ul>
           </div>

           <!-- Contact Column -->
           <div class="col-lg-4 col-md-6 reveal" style="transition-delay: 200ms">
             <h5 class="mb-4 text-dark text-uppercase tracking-wide" style="font-size: 0.9rem; letter-spacing: 2px;">Contacto</h5>
             <ul class="list-unstyled d-flex flex-column gap-3 mb-4">
               <li class="d-flex align-items-center">
                 <span class="text-muted fw-light">Miami, Florida</span>
               </li>
               <li class="d-flex align-items-center">
                 <a href="mailto:contact@coexpace.org" class="text-muted text-decoration-none fw-light footer-link">contact@coexpace.org</a>
               </li>
             </ul>
             
             <h5 class="mb-3 text-dark text-uppercase tracking-wide mt-4 pt-2" style="font-size: 0.85rem; letter-spacing: 2px;">Síguenos</h5>
             <div class="d-flex gap-3">
               <a href="https://instagram.com/coexpace" target="_blank" class="social-icon text-muted text-decoration-none transition" aria-label="Instagram">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M8 0C5.829 0 5.556.01 4.703.048 3.85.088 3.269.222 2.76.42a3.9 3.9 0 0 0-1.417.923A3.9 3.9 0 0 0 .42 2.76C.222 3.268.087 3.85.048 4.7.01 5.555 0 5.827 0 8.001c0 2.172.01 2.444.048 3.297.04.852.174 1.433.372 1.942.205.526.478.972.923 1.417.444.445.89.719 1.416.923.51.198 1.09.333 1.942.372C5.555 15.99 5.827 16 8 16s2.444-.01 3.298-.048c.851-.04 1.434-.174 1.943-.372a3.9 3.9 0 0 0 1.416-.923c.445-.445.718-.891.923-1.417.197-.509.332-1.09.372-1.942C15.99 10.445 16 10.173 16 8s-.01-2.445-.048-3.299c-.04-.851-.175-1.433-.372-1.941a3.9 3.9 0 0 0-.923-1.417A3.9 3.9 0 0 0 13.24.42c-.51-.198-1.092-.333-1.943-.372C10.443.01 10.172 0 7.998 0zm-.717 1.442h.718c2.136 0 2.389.007 3.232.046.78.036 1.204.166 1.486.275.373.145.64.319.92.599s.453.546.598.92c.11.281.24.705.275 1.485.039.843.047 1.096.047 3.231s-.008 2.389-.047 3.232c-.035.78-.166 1.203-.275 1.485a2.5 2.5 0 0 1-.599.919c-.28.28-.546.453-.92.598-.28.11-.704.24-1.485.276-.843.038-1.096.047-3.232.047s-2.39-.009-3.233-.047c-.78-.036-1.203-.166-1.485-.276a2.5 2.5 0 0 1-.92-.598 2.5 2.5 0 0 1-.6-.92c-.109-.281-.24-.705-.275-1.485-.038-.843-.046-1.096-.046-3.233s.008-2.388.046-3.231c.036-.78.166-1.204.276-1.486.145-.373.319-.64.599-.92s.546-.453.92-.598c.282-.11.705-.24 1.485-.276.738-.034 1.024-.044 2.515-.045zm4.988 1.328a.96.96 0 1 0 0 1.92.96.96 0 0 0 0-1.92m-4.27 1.122a4.109 4.109 0 1 0 0 8.217 4.109 4.109 0 0 0 0-8.217m0 1.441a2.667 2.667 0 1 1 0 5.334 2.667 2.667 0 0 1 0-5.334"/></svg>
               </a>
               <a href="https://linkedin.com/company/coexpace" target="_blank" class="social-icon text-muted text-decoration-none transition" aria-label="LinkedIn">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M0 1.146C0 .513.526 0 1.175 0h13.65C15.474 0 16 .513 16 1.146v13.708c0 .633-.526 1.146-1.175 1.146H1.175C.526 16 0 15.487 0 14.854zm4.943 12.248V6.169H2.542v7.225zm-1.2-8.212c.837 0 1.358-.554 1.358-1.248-.015-.709-.52-1.248-1.342-1.248S1.2 3.226 1.2 3.934c0 .694.521 1.248 1.327 1.248zm4.908 8.212V9.359c0-.216.016-.432.08-.586.173-.431.568-.878 1.232-.878.869 0 1.216.662 1.216 1.634v3.865h2.401V9.25c0-2.22-1.184-3.252-2.764-3.252-1.274 0-1.845.7-2.165 1.193v.025h-.016l.016-.025V6.169h-2.4c.03.678 0 7.225 0 7.225z"/></svg>
               </a>
               <a href="https://facebook.com/coexpace" target="_blank" class="social-icon text-muted text-decoration-none transition" aria-label="Facebook">
                 <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16"><path d="M16 8.049c0-4.446-3.582-8.05-8-8.05C3.58 0-.002 3.603-.002 8.05c0 4.017 2.926 7.347 6.75 7.951v-5.625h-2.03V8.05H6.75V6.275c0-2.017 1.195-3.131 3.022-3.131.876 0 1.791.157 1.791.157v1.98h-1.009c-.993 0-1.303.621-1.303 1.258v1.51h2.218l-.354 2.326H9.25V16c3.824-.604 6.75-3.934 6.75-7.951"/></svg>
               </a>
             </div>
           </div>
         </div>
         
         <div class="pt-4 mt-5 d-flex flex-column flex-md-row justify-content-between align-items-center" style="border-top: 1px solid rgba(0,0,0,0.05);">
            <p class="mb-0 text-muted small fw-light text-uppercase tracking-wide" style="letter-spacing: 1.5px; font-size: 0.75rem;">© {new Date().getFullYear()} COEXPACE. Todos los Derechos Reservados.</p>
            <div class="d-flex gap-4 mt-3 mt-md-0">
              <a href="https://coexpace.org/privacy-policy" class="text-muted small text-decoration-none fw-light footer-link">Política de Privacidad</a>
              <a href="https://coexpace.org/terms-and-conditions" class="text-muted small text-decoration-none fw-light footer-link">Términos y Condiciones</a>
            </div>
         </div>
       </div>
    </footer>
</Layout>

<style>
	main {
		margin: 0;
		padding: 0;
		width: 100%;
	}
    .footer-link { transition: color 0.3s ease; }
    .footer-link:hover { color: #d97706 !important; }
    .social-icon { 
        width: 40px; height: 40px; border-radius: 50%; border: 1px solid rgba(0,0,0,0.1); 
        display: flex; align-items: center; justify-content: center; 
        transition: all 0.3s ease; font-family: 'Cormorant Garamond', serif; 
    }
    .social-icon:hover { background-color: #d97706; color: white !important; border-color: #d97706; transform: translateY(-3px); }
</style>
