---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';

const apiUrl = import.meta.env.PUBLIC_API_URL || 'https://api-courses.coexpace.org';
const courseId = 5;

const modules = [
  { order: 1, title: "Introducción y Fundamentos", description: "Comenzamos por entender dónde estás hoy...", body: "Comenzamos por entender dónde estás hoy y por qué tu mente no se detiene.\nEjercicios prácticos para empezar a notar tus patrones automáticos.\nDa el primer paso hacia la presencia consciente." },
  { order: 2, title: "Postura, Respiración y Actitud", description: "Los cimientos de tu práctica.", body: "Aprende a usar tu cuerpo y respiración para establecer una base sólida.\nDescubre los tres pilares de una práctica de meditación diaria sostenible.\nCalibra tu mentalidad para una transformación duradera." },
  { order: 3, title: "Neurociencia y Meditación", description: "Cómo cambia tu cerebro.", body: "Descubre exactamente qué pasa en tu cerebro y sistema nervioso cuando meditas.\nAprende a reprogramar tus respuestas al estrés con técnicas basadas en ciencia.\nEntiende la neuroplasticidad y por qué la repetición es tu superpoder." },
  { order: 4, title: "Respiración y Presencia", description: "Anclándote al ahora.", body: "Técnicas de respiración profunda diseñadas para devolverte rápidamente al presente.\nCuando la vida se vuelva abrumadora, usa tu respiración como ancla.\nPractica la presencia aplicada en medio de tus momentos más ocupados." },
  { order: 5, title: "Pensamientos", description: "Desconectando del ruido.", body: "No eres tus pensamientos. Aprende a observarlos sin juzgar.\nLibérate de los bucles mentales que agotan tu energía cada día.\nPractica el arte de la distancia cognitiva y la claridad mental." },
  { order: 6, title: "Emociones", description: "Sentir sin reaccionar.", body: "Navega las emociones intensas con técnicas de equilibrio y regulación emocional.\nAprende la diferencia entre reaccionar y responder desde la calma.\nConstruye tu vocabulario emocional y tu músculo de resiliencia interior." },
  { order: 7, title: "Hábitos e Inteligencia del Corazón", description: "Creando un estilo de vida sostenible.", body: "Integra estas prácticas en tu rutina diaria sin problemas.\nConstruye resiliencia y coherencia corazón-cerebro para un bienestar a largo plazo.\nDiseña tu propio ritual sostenible que realmente se adapte a tu vida." },
  { order: 8, title: "29 Meditaciones Guiadas", description: "Tu kit de herramientas diario.", body: "Acceso a 29 meditaciones guiadas diseñadas específicamente para cada momento.\nMeditaciones para la ansiedad, el sueño, el enfoque y la regulación emocional.\nTu calma portátil — disponible desde cualquier dispositivo, en cualquier momento." },
];

const faqs = [
  { question: "¿Cuánto tiempo necesito al día?", answer: "Con solo 10 a 15 minutos al día, puedes empezar a notar cambios reales en tu claridad mental y reducción de la ansiedad." },
  { question: "¿Necesito experiencia previa en meditación?", answer: "No, en absoluto. El Método Mayim está diseñado desde cero. Aprenderás las bases y avanzarás paso a paso." },
  { question: "¿Cómo accedo al material?", answer: "Obtienes acceso inmediato a nuestra plataforma Coexpace LMS al inscribirte. Puedes iniciar sesión desde cualquier dispositivo." },
  { question: "¿El curso caduca?", answer: "¡Tendrás acceso de por vida! Practica a tu propio ritmo, donde y cuando quieras." },
];
---

<Layout title="Meditación y Mindfulness para la Vida Diaria | COEXPACE">
  <Navbar />

  <!-- Language Floater: shows ESP flag to go back to Spanish -->
  <a href="/en" title="Switch to English" aria-label="Switch to English" style="position:fixed;right:24px;bottom:32px;z-index:99999;width:50px;height:50px;border-radius:50%;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border:1px solid rgba(0,0,0,0.10);box-shadow:0 4px 20px rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;overflow:hidden;transition:transform 0.25s ease,box-shadow 0.25s ease;text-decoration:none;" onmouseenter="this.style.transform='scale(1.12) translateY(-3px)';this.style.boxShadow='0 8px 30px rgba(0,0,0,0.2)';" onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.15)';">
    <img src="https://flagcdn.com/w80/us.png" alt="English" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;" />
  </a>

  <main>

    <!-- ===== HERO ===== -->
    <section class="hero-en" id="hero">
      <div class="hero-bg-en"></div>
      <div class="container position-relative z-2 reveal text-center">
        <span class="badge-pill-en">Edición Masterclass</span>
        <h1 class="hero-title-en">Encuentra tu <em class="text-amber">Calma</em><br/>en el Caos</h1>
        <p class="hero-sub-en">Un sistema premium diseñado para mujeres que compaginan el trabajo, la familia y la ansiedad. Deja de vivir en piloto automático y recupera tu claridad hoy.</p>
        <div class="d-flex flex-column align-items-center">
          <a href="#checkout" class="btn-amber-en mb-4">Inscríbete Ahora</a>
          <p class="small text-muted" style="letter-spacing:1px;"><span class="text-amber">★</span> Únete a cientos de mujeres que ya están transformando sus vidas</p>
        </div>
      </div>
    </section>

    <!-- ===== SOCIAL PROOF ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-4 reveal">
        <div class="row align-items-center">
          <div class="col-lg-5 mb-5 mb-lg-0">
            <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:400;color:#1c1917;">Por Qué Este Curso<br><em class="text-amber">Es Diferente</em></h2>
            <div style="width:40px;height:1px;background:#d97706;margin:1.2rem 0 1.5rem;"></div>
            <p style="font-family:'Inter',sans-serif;color:#78716c;font-size:1.1rem;line-height:1.8;font-weight:300;">Este no es un curso para aprender a meditar. Es un sistema para dejar de vivir en piloto automático, incluso cuando la vida no se detiene.</p>
          </div>
          <div class="col-lg-7">
            <div class="row g-4 text-center">
              {[["7","Módulos","de transformación"],["14","Cuadernos","aplicación en el mundo real"],["29","Audios","meditaciones guiadas"]].map(([num,label,sub]) => (
                <div class="col-sm-4">
                  <div class="p-4 h-100 bg-white text-center" style="border:1px solid #e7e5e4;border-top:2.5px solid #d97706;border-radius:6px;box-shadow:0 2px 12px rgba(0,0,0,0.05);">
                    <span class="d-block text-dark" style="font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:300;line-height:1;margin-bottom:0.5rem;">{num}</span>
                    <strong class="d-block text-uppercase" style="font-family:'Inter',sans-serif;font-size:0.72rem;letter-spacing:2px;color:#d97706;margin-bottom:0.3rem;">{label}</strong>
                    <span style="font-family:'Inter',sans-serif;font-size:0.8rem;color:#a8a29e;font-style:italic;">{sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TESTIMONIALS ===== -->
    <section class="testi-section-es py-5">
      <div class="container py-5">

        <div class="text-center mb-5 pb-2 reveal">
          <span class="text-amber fw-bold text-uppercase small" style="letter-spacing:2px;">Lo Que Dicen Ellas</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:400;color:#1c1917;margin-top:0.75rem;">Mujeres Reales. Transformaciones Reales.</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>

        <!-- Featured testimonial -->
        <div class="row justify-content-center mb-4 reveal">
          <div class="col-lg-9">
            <div class="testi-featured-es position-relative">
              <div class="testi-bigquote-es">"</div>
              <div class="testi-stars-es mb-4">★★★★★</div>
              <p style="font-family:'Cormorant Garamond',serif;font-size:1.55rem;font-weight:400;font-style:italic;color:#1c1917;line-height:1.75;margin:0 0 2rem;position:relative;z-index:1;">
                "Cada sesión siento que he trabajado un aspecto diferente de mi vida. He adquirido una valiosa herramienta para controlar mis emociones — y no ellas a mí. La guía de Vivían me ayudó a enfrentar situaciones de crisis y a encontrarme a mí misma."
              </p>
              <p style="font-family:'Cormorant Garamond',serif;font-size:1.2rem;font-weight:500;color:#1c1917;margin:0;line-height:1.2;">— María José</p>
            </div>
          </div>
        </div>

        <!-- Three compact cards -->
        <div class="row g-4 justify-content-center">
          {[
            {
              quote: "La meditación le dio un nuevo giro a mi vida. Me ayudó a encontrar paz interior en momentos de angustia, a darle color a lo que está en blanco y negro — y lo más importante, a encontrarme a mí misma para encontrar mi propia felicidad.",
              name: "Paulina R.",
              initial: "P"
            },
            {
              quote: "He sentido muchos cambios al aprender a meditar, a respirar y a vivir en el momento presente. Lo he aplicado con mis hijos también — los cambios que han hecho son increíbles. Este es un curso muy efectivo.",
              name: "Lucy Penhos",
              initial: "L"
            },
            {
              quote: "Durante muchos años lo intenté con varios maestros y nunca logré entender el fondo de este gran regalo que es meditar — hasta Vivían. Vivir en el aquí y ahora es sanador. Lo recomiendo profundamente.",
              name: "Diana S.",
              initial: "D"
            },
          ].map(({ quote, name, initial }, i) => (
            <div class="col-md-4 reveal" style={`transition-delay:${i * 100}ms`}>
              <div class="testi-card-es h-100 d-flex flex-column">
                <div class="testi-stars-es mb-3" style="font-size:0.85rem;">★★★★★</div>
                <p style="font-family:'Inter',sans-serif;font-size:0.95rem;color:#57534e;font-style:italic;line-height:1.8;flex:1;margin:0 0 1.5rem;">"{quote}"</p>
                <p style="font-family:'Cormorant Garamond',serif;font-size:1.1rem;font-weight:500;color:#1c1917;margin:0;">— {name}</p>
              </div>
            </div>
          ))}
        </div>

      </div>
    </section>

    <!-- ===== PROBLEM / SOLUTION ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:#1c1917;letter-spacing:0.5px;">¿Es Esta Tu Realidad?</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-4 justify-content-center">
          {[
            ["01","El Bucle Interminable","Sientes que tu mente nunca se apaga, ni siquiera al intentar dormir. El ruido mental es constante."],
            ["02","Sobrecarga Total","Llevas el peso del trabajo y la familia, sintiendo que simplemente \"no puedes con todo\". La presión es abrumadora."],
            ["03","Reactividad","Reaccionas de forma impulsiva o emocional al estrés diario, seguido de culpa. Buscas equilibrio pero encuentras fricción."],
            ["04","Buscando la Verdad","Buscas herramientas que funcionen en tu rutina real, no en un retiro en el Tíbet."],
          ].map(([n, title, text], i) => (
            <div class={`col-md-6 ${i===0||i===3?'col-lg-5':'col-lg-7'} reveal`} style={`transition-delay:${i*100}ms`}>
              <div class="light-panel p-5 h-100 d-flex flex-column justify-content-center">
                <span class="text-amber fs-3 mb-3">{n}</span>
                <h4 style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:400;color:#1c1917;margin-bottom:1rem;">{title}</h4>
                <p class="text-muted fw-light lh-lg mb-0">{text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== TRANSFORMATION ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-amber fw-bold text-uppercase small" style="letter-spacing:2px;">Lo Que Lograrás</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">Tu Transformación</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-0 reveal" style="border-radius:8px;overflow:hidden;background:#fff;box-shadow:0 4px 30px rgba(0,0,0,0.06);">
          <div class="col-md-6 transf-panel-es" style="background:#faf8f5;border-right:1px solid #e7e5e4;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#78716c;margin-bottom:2.5rem;">Antes (El Caos)</h3>
            <ul class="list-unstyled">
              {["Sobrecarga y ansiedad constante","Insomnio y agotamiento","Reacciones explosivas","Desconexión total"].map(item => (
                <li style="color:#78716c;font-size:1.1rem;margin-bottom:1.5rem;display:flex;align-items:start;font-weight:300;"><span style="opacity:0.5;margin-right:12px;color:#78716c;">✕</span>{item}</li>
              ))}
            </ul>
          </div>
          <div class="col-md-6 transf-panel-es" style="background:#fff;position:relative;">
            <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:radial-gradient(circle at top right,rgba(217,119,6,0.05),transparent);pointer-events:none;"></div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#d97706;margin-bottom:2.5rem;">Después (Mente en Paz)</h3>
            <ul class="list-unstyled position-relative" style="z-index:1;">
              {["Calma y reducción de la ansiedad cuando más lo necesitas","Mejor descanso y despertar con energía real","Responder desde la calma y al equilibrio emocional","Usar tu cuerpo como ancla para volver al presente"].map(item => (
                <li style="color:#1c1917;font-size:1.1rem;margin-bottom:1.5rem;display:flex;align-items:start;font-weight:400;"><span style="color:#d97706;margin-right:12px;">✦</span>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROGRAM / MODULES SLIDER ===== -->
    <section class="py-5 my-5" style="background-color:transparent;">
      <div class="container py-5 reveal">
        <div class="text-center mb-5">
          <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">El Esquema</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">El Método Mayim</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 1rem;"></div>
          <p style="font-family:'Inter',sans-serif;color:#78716c;font-size:1.05rem;font-weight:300;">Un camino paso a paso meticulosamente diseñado para tu transformación.</p>
        </div>
        <div class="slider-wrapper-en position-relative w-100">
          <div class="magazine-slider-en d-flex shadow-sm" id="esSlider">
            {modules.map((mod, index) => (
              <div class="magazine-card-es bg-white p-4 position-relative d-flex flex-column border-end">
                <div class="position-absolute user-select-none" style="top:10px;right:16px;font-family:'Cormorant Garamond',serif;font-size:7rem;line-height:1;z-index:0;color:#d97706;opacity:0.12;font-weight:700;">0{index+1}</div>
                <div class="position-relative d-flex flex-column" style="z-index:1;">
                  <span class="text-amber text-uppercase fw-bold mb-2 d-block" style="letter-spacing:1px;font-size:0.75rem;">Módulo {index+1}</span>
                  <h3 class="text-dark fw-normal mb-3" style="font-family:'Cormorant Garamond',serif;font-size:1.6rem;line-height:1.2;">{mod.title}</h3>
                  <p class="text-muted fw-light mb-3 pb-3" style="font-style:italic;border-bottom:1px solid rgba(0,0,0,0.05);font-size:0.9rem;line-height:1.5;">{mod.description}</p>
                  <ul class="list-unstyled mb-0 d-flex flex-column gap-2">
                    {mod.body.split('\n').filter(l => l.trim()).map(line => (
                      <li class="d-flex align-items-start">
                        <span class="text-amber me-2" style="font-size:0.7rem;margin-top:4px;">✦</span>
                        <span class="text-muted fw-light" style="font-size:0.85rem;line-height:1.55;">{line.replace(/^- /,'')}</span>
                      </li>
                    ))}
                  </ul>
                </div>
              </div>
            ))}
          </div>
          <div class="slider-fade-en right"></div>
          <div class="slider-fade-en left"></div>
        </div>
      </div>
    </section>

    <!-- ===== INSTRUCTOR ===== -->
    <section class="py-5 bg-white">
      <div class="container py-5 reveal">
        <div class="row align-items-center">
          <div class="col-lg-5 mb-5 mb-lg-0">
            <img src="/images/vivian.webp" alt="Vivian Toussieh" style="width:100%;aspect-ratio:1/1;object-fit:cover;object-position:top;border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,0.10);">
          </div>
          <div class="col-lg-7 px-lg-5">
            <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">Tu Guía</span>
            <h2 class="mb-4 mt-2" style="font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:400;color:#1c1917;">Vivian Toussieh</h2>
            <div style="width:60px;height:1px;background:#d97706;margin-bottom:1.5rem;"></div>
            <p style="font-family:'Inter',sans-serif;font-size:1.1rem;color:#78716c;line-height:1.8;font-weight:300;margin-bottom:1.5rem;">Vivian Toussieh es psicóloga, escritora y fundadora de Coexpace. Como madre y profesional, entiende de primera mano el desafío de mantener la calma cuando la vida no se detiene.</p>
            <p style="font-family:'Inter',sans-serif;color:#78716c;line-height:1.8;font-weight:300;margin-bottom:2.5rem;">Es co-creadora del Método Mayim, un enfoque de meditación diseñado para la vida real, no para un retiro. Ha guiado a cientos de personas transformando la ansiedad y el agobio en profunda claridad y estabilidad interior.</p>
            <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#1c1917;font-style:italic;border-left:2px solid #d97706;padding-left:20px;">"No necesitas más tiempo. Necesitas las herramientas adecuadas."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== BONUSES / MASTERCLASSES ===== -->
    <section class="py-5 bg-white">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">Expertos Invitados</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">Masterclasses Incluidas</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 1rem;"></div>
          <p style="font-family:'Inter',sans-serif;color:#78716c;font-weight:300;">Accede a perspectivas exclusivas de especialistas reconocidos mundialmente.</p>
        </div>
        <div class="row g-4 mt-4">
          {[
            { n:"01", img:"member-6.webp", name:"Dra. Edith Shiro", talk:"El Camino del Dolor al Propósito", desc:"Una profunda conferencia sobre cómo transformar el dolor en un propósito de vida, con profundidad clínica." },
            { n:"02", img:"member-7.webp", name:"Dr. Manuel Ortega", talk:"Ansiedad y Depresión", desc:"Claves para comprender y manejar la ansiedad desde una perspectiva clínica y humana." },
            { n:"03", img:"member-10.webp", name:"Dr. Ángel Oropeza", talk:"Raíces del Fanatismo", desc:"Un revelador análisis sobre los orígenes del fanatismo y el bienestar emocional." },
          ].map((expert, i) => (
            <div class="col-md-4 reveal" style={`transition-delay:${i*100}ms`}>
              <div class="p-5 h-100 bg-white position-relative overflow-hidden" style="border:1px solid #e7e5e4;border-radius:1rem;transition:all 0.3s ease;">
                <div class="position-absolute text-amber opacity-25 display-1" style="top:0;right:1rem;font-family:'Cormorant Garamond',serif;margin-top:0.5rem;">{expert.n}</div>
                <div style="position:relative;display:inline-block;margin-bottom:2rem;z-index:1;">
                  <div style="position:absolute;width:110px;height:110px;background:rgba(217,119,6,0.15);border-radius:50%;top:-5px;left:-15px;z-index:0;"></div>
                  <img src={`https://coexpace.org/_next/image?url=%2Fhome%2Fevents%2Fspeakers%2F${expert.img}&w=256&q=75`} alt={expert.name} style="position:relative;z-index:1;width:100px;height:100px;object-fit:cover;border-radius:50%;border:3px solid #fff;box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                </div>
                <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:#1c1917;position:relative;z-index:1;">{expert.name}</h4>
                <p style="color:#d97706;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;margin:1rem 0;font-family:'Inter',sans-serif;position:relative;z-index:1;">{expert.talk}</p>
                <p style="color:#78716c;font-weight:300;line-height:1.7;font-family:'Inter',sans-serif;position:relative;z-index:1;">{expert.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== STEPS ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5 reveal">
        <div class="text-center mb-5 pb-4">
          <span class="text-amber fw-bold text-uppercase small" style="letter-spacing:2px;">El Proceso</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">Tu Viaje Comienza Aquí</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-4 justify-content-center mt-2 align-items-stretch">
          {[
            ["I","Inscríbete Hoy","Un único pago seguro. Sin suscripciones ni cargos ocultos jamás."],
            ["II","Obtén Acceso","Acceso inmediato a todos los módulos premium y clases magistrales de los expertos."],
            ["III","Transfórmate","Avanza a tu propio ritmo, desde cualquier lugar y cuando quieras. Acceso de por vida."],
          ].map(([roman, title, text], i) => (
            <div class="col-md-4 d-flex reveal" style={`transition-delay:${i*100}ms`}>
              <div class="step-card-es w-100 d-flex flex-column align-items-center text-center bg-white" style="border-radius:1rem;box-shadow:0 2px 12px rgba(0,0,0,0.06);border:1px solid #e7e5e4;padding:2.75rem 2rem;transition:all 0.3s ease;">
