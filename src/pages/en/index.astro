<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('enSlider');
    if (!slider) return;

    let isHovering = false;
    slider.addEventListener('mouseenter', () => isHovering = true);
    slider.addEventListener('mouseleave', () => isHovering = false);
    slider.addEventListener('touchstart', () => isHovering = true, { passive: true });
    slider.addEventListener('touchend', () => { setTimeout(() => isHovering = false, 2000); }, { passive: true });

    const dots = document.querySelectorAll('.en-dot');
    slider.addEventListener('scroll', () => {
      const cardWidth = window.innerWidth <= 768 ? 320 : 450;
      let idx = Math.round(slider.scrollLeft / cardWidth);
      if (idx >= dots.length) idx = dots.length - 1;
      dots.forEach((d, i) => d.classList.toggle('active', i === idx));
    });

    dots.forEach(dot => {
      dot.addEventListener('click', (e) => {
        isHovering = true;
        setTimeout(() => isHovering = false, 4000);
        const i = parseInt((e.target as HTMLElement).dataset.idx || '0');
        const cardWidth = window.innerWidth <= 768 ? 320 : 450;
        slider.scrollTo({ left: i * cardWidth, behavior: 'smooth' });
      });
    });

    const auto = setInterval(() => {
      if (!isHovering) {
        const card = window.innerWidth <= 768 ? 320 : 450;
        if (slider.scrollLeft >= slider.scrollWidth - slider.clientWidth - 10) {
          slider.scrollTo({ left: 0, behavior: 'smooth' });
        } else {
          slider.scrollBy({ left: card, behavior: 'smooth' });
        }
      }
    }, 3500);

    // Reveal on scroll
    const reveals = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('visible'); observer.unobserve(e.target); } });
    }, { threshold: 0.1 });
    reveals.forEach(r => observer.observe(r));
  });
</script>
