---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';

const modules = [
  { order: 1, title: "Introduction & Foundations", description: "We start by understanding where you are today...", body: "We start by understanding where you are today and why your mind won't stop.\nPractical exercises to begin noticing your automatic patterns.\nTake the first step toward conscious presence." },
  { order: 2, title: "Posture, Breathing & Attitude", description: "The foundations of your practice.", body: "Learn how to use your body and breathing to establish a solid foundation.\nDiscover the three pillars of a sustainable daily meditation practice.\nCalibrate your mindset for lasting transformation." },
  { order: 3, title: "Neuroscience & Meditation", description: "How your brain changes.", body: "Discover exactly what happens in your brain and nervous system when you meditate.\nLearn how to rewire your stress responses with science-backed techniques.\nUnderstand neuroplasticity and why repetition is your superpower." },
  { order: 4, title: "Breathing & Presence", description: "Anchoring to the now.", body: "Deeper breathing techniques designed to rapidly bring you back to the present.\nWhen life feels overwhelming, use your breath as your anchor.\nPractice applied presence in the middle of your busiest moments." },
  { order: 5, title: "Thoughts", description: "Detaching from the noise.", body: "You are not your thoughts. Learn to observe them without judgment.\nBreak free from mental loops that drain your energy every day.\nPractice the art of cognitive distance and mental clarity." },
  { order: 6, title: "Emotions", description: "Feeling without reacting.", body: "Navigate intense emotions with balance and emotional regulation techniques.\nLearn the difference between reacting and responding from calm.\nBuild your emotional vocabulary and your inner resilience muscle." },
  { order: 7, title: "Habits & Heart Intelligence", description: "Creating a sustainable lifestyle.", body: "Integrate these practices into your daily routine seamlessly.\nBuild resilience and heart-brain coherence for long-term wellbeing.\nDesign your own sustainable ritual that actually fits your life." },
  { order: 8, title: "29 Guided Meditations", description: "Your daily toolkit.", body: "Access to 29 specifically designed guided meditations for every moment.\nMeditations for anxiety, sleep, focus, and emotional regulation.\nYour portable calm — available from any device, anytime." },
];

const faqs = [
  { question: "How much time do I need per day?", answer: "With just 10 to 15 minutes a day, you can start noticing real changes in your mental clarity and anxiety reduction." },
  { question: "Do I need previous meditation experience?", answer: "No, not at all. The Mayim Method is designed from scratch. You will learn the basics and advance step by step." },
  { question: "How do I access the material?", answer: "You get immediate access to our Coexpace LMS platform as soon as you enroll. You can log in from any device." },
  { question: "Does the course expire?", answer: "You will have lifetime access! Practice at your own pace, wherever and whenever you want." },
];
---

<Layout title="Meditation and Mindfulness for Daily Life | COEXPACE">
  <Navbar />

  <!-- Language Floater: shows ESP flag to go back to Spanish -->
  <a href="/" title="Cambiar a Español" aria-label="Cambiar a Español" style="position:fixed;right:24px;bottom:32px;z-index:99999;width:50px;height:50px;border-radius:50%;background:rgba(255,255,255,0.95);backdrop-filter:blur(12px);border:1px solid rgba(0,0,0,0.10);box-shadow:0 4px 20px rgba(0,0,0,0.15);display:flex;align-items:center;justify-content:center;overflow:hidden;transition:transform 0.25s ease,box-shadow 0.25s ease;text-decoration:none;" onmouseenter="this.style.transform='scale(1.12) translateY(-3px)';this.style.boxShadow='0 8px 30px rgba(0,0,0,0.2)';" onmouseleave="this.style.transform='scale(1)';this.style.boxShadow='0 4px 20px rgba(0,0,0,0.15)';">
    <img src="https://flagcdn.com/w80/es.png" alt="Español" style="width:100%;height:100%;object-fit:cover;border-radius:50%;display:block;" />
  </a>

  <main>

    <!-- ===== HERO ===== -->
    <section class="hero-en" id="hero">
      <div class="hero-bg-en"></div>
      <div class="container position-relative z-2 reveal text-center">
        <span class="badge-pill-en">Masterclass Edition</span>
        <h1 class="hero-title-en">Find Your <em class="text-amber">Calm</em><br/>in the Chaos</h1>
        <p class="hero-sub-en">A premium system designed for women who juggle work, family, and anxiety. Stop living on autopilot and reclaim your clarity today.</p>
        <div class="d-flex flex-column align-items-center">
          <a href="#checkout" class="btn-amber-en mb-4">Enroll Now</a>
          <p class="small text-muted" style="letter-spacing:1px;"><span class="text-amber">★</span> Join hundreds of women already transforming their lives</p>
        </div>
      </div>
    </section>

    <!-- ===== SOCIAL PROOF ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-4 reveal">
        <div class="row align-items-center">
          <div class="col-lg-5 mb-5 mb-lg-0">
            <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.5rem;font-weight:400;color:#1c1917;">Why This Course<br><em class="text-amber">Is Different</em></h2>
            <div style="width:40px;height:1px;background:#d97706;margin:1.2rem 0 1.5rem;"></div>
            <p style="font-family:'Inter',sans-serif;color:#78716c;font-size:1.1rem;line-height:1.8;font-weight:300;">This is not a course to learn how to meditate. It's a system to stop living on autopilot, even when life doesn't stop.</p>
          </div>
          <div class="col-lg-7">
            <div class="row g-4 text-center">
              {[["7","Modules","of transformation"],["14","Workbooks","real-world application"],["29","Audio","guided meditations"]].map(([num,label,sub]) => (
                <div class="col-sm-4">
                  <div class="light-panel p-4 h-100 bg-white shadow-sm" style="border-top:2px solid rgba(217,119,6,0.4);border:1px solid #e7e5e4;border-radius:4px;">
                    <span class="d-block display-3 text-dark mb-2" style="font-family:'Cormorant Garamond',serif;">{num}</span>
                    <strong class="d-block fs-6 text-amber text-uppercase" style="letter-spacing:1px;">{label}</strong>
                    <span class="text-muted small fst-italic">{sub}</span>
                  </div>
                </div>
              ))}
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== TESTIMONIAL ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5 reveal">
        <div class="text-center mb-5">
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.3rem;font-weight:400;color:#1c1917;">Real Women. Real Transformations.</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row justify-content-center">
          <div class="col-md-8 col-lg-7">
            <div class="p-5 position-relative bg-white shadow-sm text-center" style="border-radius:1rem;border:1px solid #e7e5e4;">
              <div style="position:absolute;top:10px;right:30px;font-family:'Cormorant Garamond',serif;font-size:6rem;color:#d97706;opacity:0.2;line-height:1;">"</div>
              <div class="d-flex flex-column align-items-center mb-4 position-relative z-1">
                <img src="/images/student.png" alt="Sarah J." class="rounded-circle mb-3" width="80" height="80" style="object-fit:cover;border:2px solid rgba(217,119,6,0.3);">
                <h5 style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;font-weight:400;color:#1c1917;margin:0 0 4px;">Sarah Jenkins</h5>
                <span style="color:#d97706;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;font-family:'Inter',sans-serif;">Marketing Director</span>
              </div>
              <p style="font-family:'Inter',sans-serif;font-size:1.05rem;color:#78716c;font-style:italic;line-height:1.8;position:relative;z-index:1;margin:0;">"The best investment I've made. My impulsive reactions have significantly decreased, and my relationship with stress at work completely changed. The tools are actually usable during a busy day."</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROBLEM / SOLUTION ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:300;color:#1c1917;letter-spacing:0.5px;">Is This Your Reality?</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-4 justify-content-center">
          {[
            ["01","The Endless Loop","You feel like your mind never shuts off, not even when trying to sleep. The noise is constant."],
            ["02","Total Overload","You carry the weight of work and family, feeling like you simply \"can't do it all\". The pressure is overwhelming."],
            ["03","Reactivity","You react impulsively or emotionally to daily stress, followed by guilt. You seek balance but find friction."],
            ["04","Seeking Truth","You're looking for tools that work in your real routine, not on a retreat in Tibet."],
          ].map(([n, title, text], i) => (
            <div class={`col-md-6 ${i===0||i===3?'col-lg-5':'col-lg-7'} reveal`} style={`transition-delay:${i*100}ms`}>
              <div class="light-panel p-5 h-100 d-flex flex-column justify-content-center">
                <span class="text-amber fs-3 mb-3">{n}</span>
                <h4 style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:400;color:#1c1917;margin-bottom:1rem;">{title}</h4>
                <p class="text-muted fw-light lh-lg mb-0">{text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== TRANSFORMATION ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-amber fw-bold text-uppercase small" style="letter-spacing:2px;">What You Will Achieve</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">Your Transformation</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-0 reveal" style="border-radius:8px;overflow:hidden;background:#fff;box-shadow:0 4px 30px rgba(0,0,0,0.06);">
          <div class="col-md-6" style="padding:60px 50px;background:#faf8f5;border-right:1px solid #e7e5e4;">
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#78716c;margin-bottom:2.5rem;">Before (The Chaos)</h3>
            <ul class="list-unstyled">
              {["Constant overload and anxiety","Insomnia and exhaustion","Explosive reactions","Total disconnection"].map(item => (
                <li style="color:#78716c;font-size:1.1rem;margin-bottom:1.5rem;display:flex;align-items:start;font-weight:300;"><span style="opacity:0.5;margin-right:12px;color:#78716c;">✕</span>{item}</li>
              ))}
            </ul>
          </div>
          <div class="col-md-6" style="padding:60px 50px;background:#fff;position:relative;">
            <div style="position:absolute;top:0;left:0;width:100%;height:100%;background:radial-gradient(circle at top right,rgba(217,119,6,0.05),transparent);pointer-events:none;"></div>
            <h3 style="font-family:'Cormorant Garamond',serif;font-size:2rem;color:#d97706;margin-bottom:2.5rem;">After (Mind at Peace)</h3>
            <ul class="list-unstyled position-relative" style="z-index:1;">
              {["Calm and anxiety reduction when you need it most","Better sleep and waking up with real energy","Responding from calm and emotional balance","Using your body as an anchor to return to the present"].map(item => (
                <li style="color:#1c1917;font-size:1.1rem;margin-bottom:1.5rem;display:flex;align-items:start;font-weight:400;"><span style="color:#d97706;margin-right:12px;">✦</span>{item}</li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== PROGRAM / MODULES SLIDER ===== -->
    <section class="py-5 my-5" style="background-color:transparent;">
      <div class="container py-5 reveal">
        <div class="text-center mb-5">
          <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">The Blueprint</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">The Mayim Method</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 1rem;"></div>
          <p style="font-family:'Inter',sans-serif;color:#78716c;font-size:1.05rem;font-weight:300;">A step-by-step path meticulously designed for your transformation.</p>
        </div>
        <div class="slider-wrapper-en position-relative w-100">
          <div class="magazine-slider-en d-flex shadow-sm" id="enSlider">
            {modules.map((mod, index) => (
              <div class="magazine-card-en bg-white p-5 position-relative d-flex flex-column h-100 border-end">
                <div class="position-absolute opacity-10 fw-bold user-select-none" style="top:10px;right:20px;font-family:'Cormorant Garamond',serif;font-size:10rem;line-height:1;z-index:0;color:#d97706;">0{index+1}</div>
                <div class="position-relative d-flex flex-column h-100" style="z-index:1;">
                  <span class="text-amber text-uppercase small fw-bold mb-3 d-block" style="letter-spacing:1px;">Module {index+1}</span>
                  <h3 class="text-dark fw-normal mb-4" style="font-family:'Cormorant Garamond',serif;font-size:2rem;min-height:4rem;">{mod.title}</h3>
                  <p class="text-muted fs-6 fw-light mb-4 pb-4 flex-grow-0" style="font-style:italic;border-bottom:1px solid rgba(0,0,0,0.05);">{mod.description}</p>
                  <div class="flex-grow-1 overflow-auto pe-2" style="max-height:250px;">
                    <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
                      {mod.body.split('\n').filter(l => l.trim()).map(line => (
                        <li class="d-flex align-items-start">
                          <span class="text-amber me-2" style="font-size:0.8rem;margin-top:5px;">✦</span>
                          <span class="text-muted fw-light small lh-base">{line.replace(/^- /,'')}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="slider-fade-en right"></div>
          <div class="slider-fade-en left"></div>
        </div>
        <div class="d-flex justify-content-center gap-2 mt-4" id="enPagination">
          {modules.map((_, i) => (
            <button class={`en-dot ${i===0?'active':''}`} data-idx={i} aria-label={`Slide ${i+1}`}></button>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== INSTRUCTOR ===== -->
    <section class="py-5 bg-white">
      <div class="container py-5 reveal">
        <div class="row align-items-center">
          <div class="col-lg-5 mb-5 mb-lg-0">
            <div class="position-relative">
              <div class="position-absolute w-100 h-100" style="top:-15px;left:-15px;z-index:0;background:#faf8f5;border:1px solid rgba(0,0,0,0.1);"></div>
              <img src="/images/vivian.webp" alt="Vivian Toussieh" class="img-fluid position-relative shadow-md" style="object-fit:cover;aspect-ratio:4/5;width:100%;border:4px solid white;border-radius:4px;z-index:1;">
            </div>
          </div>
          <div class="col-lg-7 px-lg-5">
            <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">Your Guide</span>
            <h2 class="mb-4 mt-2" style="font-family:'Cormorant Garamond',serif;font-size:3.5rem;font-weight:400;color:#1c1917;">Vivian Toussieh</h2>
            <div style="width:60px;height:1px;background:#d97706;margin-bottom:1.5rem;"></div>
            <p style="font-family:'Inter',sans-serif;font-size:1.1rem;color:#78716c;line-height:1.8;font-weight:300;margin-bottom:1.5rem;">Vivian Toussieh is a psychologist, writer, and founder of Coexpace. As a mother and professional, she understands firsthand the challenge of staying calm when life doesn't stop.</p>
            <p style="font-family:'Inter',sans-serif;color:#78716c;line-height:1.8;font-weight:300;margin-bottom:2.5rem;">She is the co-creator of the Mayim Method, a meditation approach designed for real life — not for a retreat. She has guided hundreds of people in transforming anxiety and overwhelm into profound clarity and inner stability.</p>
            <p style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:#1c1917;font-style:italic;border-left:2px solid #d97706;padding-left:20px;">"You don't need more time. You need the right tools."</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== BONUSES / MASTERCLASSES ===== -->
    <section class="py-5 bg-white">
      <div class="container py-5">
        <div class="text-center mb-5 reveal">
          <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">Guest Experts</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">Included Masterclasses</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 1rem;"></div>
          <p style="font-family:'Inter',sans-serif;color:#78716c;font-weight:300;">Unlock exclusive insights from world-renowned specialists.</p>
        </div>
        <div class="row g-4 mt-4">
          {[
            { n:"01", img:"member-6.webp", name:"Dr. Edith Shiro", talk:"The Path from Pain to Purpose", desc:"A profound conference on transforming pain into life purpose, with clinical depth." },
            { n:"02", img:"member-7.webp", name:"Dr. Manuel Ortega", talk:"Anxiety and Depression", desc:"Keys to understanding and managing anxiety from a clinical and human perspective." },
            { n:"03", img:"member-10.webp", name:"Dr. Ángel Oropeza", talk:"Roots of Fanaticism", desc:"A revealing analysis of the origins of fanaticism and emotional well-being." },
          ].map((expert, i) => (
            <div class="col-md-4 reveal" style={`transition-delay:${i*100}ms`}>
              <div class="p-5 h-100 bg-white position-relative overflow-hidden" style="border:1px solid #e7e5e4;border-radius:1rem;transition:all 0.3s ease;">
                <div class="position-absolute text-amber opacity-25 display-1" style="top:0;right:1rem;font-family:'Cormorant Garamond',serif;margin-top:0.5rem;">{expert.n}</div>
                <div style="position:relative;display:inline-block;margin-bottom:2rem;z-index:1;">
                  <div style="position:absolute;width:110px;height:110px;background:rgba(217,119,6,0.15);border-radius:50%;top:-5px;left:-15px;z-index:0;"></div>
                  <img src={`https://coexpace.org/_next/image?url=%2Fhome%2Fevents%2Fspeakers%2F${expert.img}&w=256&q=75`} alt={expert.name} style="position:relative;z-index:1;width:100px;height:100px;object-fit:cover;border-radius:50%;border:3px solid #fff;box-shadow:0 4px 10px rgba(0,0,0,0.05);">
                </div>
                <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;color:#1c1917;position:relative;z-index:1;">{expert.name}</h4>
                <p style="color:#d97706;font-size:0.8rem;text-transform:uppercase;letter-spacing:1px;margin:1rem 0;font-family:'Inter',sans-serif;position:relative;z-index:1;">{expert.talk}</p>
                <p style="color:#78716c;font-weight:300;line-height:1.7;font-family:'Inter',sans-serif;position:relative;z-index:1;">{expert.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== STEPS ===== -->
    <section class="py-5" style="background-color:transparent;">
      <div class="container py-5 reveal">
        <div class="text-center mb-5 pb-4">
          <span class="text-amber fw-bold text-uppercase small" style="letter-spacing:2px;">The Process</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">Your Journey Begins</h2>
          <div style="width:40px;height:1px;background:#d97706;margin:1.2rem auto 0;"></div>
        </div>
        <div class="row g-5 justify-content-center mt-2">
          {[
            ["I","Enroll Today","One-time secure payment. No subscriptions or hidden charges ever."],
            ["II","Get Access","Immediate access to all the premium modules and expert masterclasses."],
            ["III","Transform","Practice at your own pace, wherever and whenever you want. Lifetime access."],
          ].map(([roman, title, text], i) => (
            <div class="col-md-4 text-center reveal" style={`transition-delay:${i*100}ms`}>
              <div class="position-relative p-4 h-100 bg-white" style="border-radius:1rem;box-shadow:0 2px 12px rgba(0,0,0,0.06);border:1px solid #e7e5e4;overflow:hidden;transition:all 0.3s ease;">
                <div style="position:absolute;top:16px;left:20px;font-family:'Cormorant Garamond',serif;font-size:5rem;font-weight:300;line-height:1;color:#d97706;opacity:0.15;user-select:none;z-index:0;">{roman}</div>
                <div class="position-relative pt-5" style="z-index:1;">
                  <h4 style="font-family:'Cormorant Garamond',serif;font-size:1.8rem;font-weight:400;color:#1c1917;margin-top:1.5rem;">{title}</h4>
                  <p style="font-family:'Inter',sans-serif;color:#78716c;font-weight:300;margin-top:1rem;padding:0 1rem;">{text}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ===== PRICING ===== -->
    <section class="py-5 my-3" id="checkout">
      <div class="container py-5 reveal">
        <div class="text-center mb-5 pb-2">
          <span class="text-amber text-uppercase small fw-bold" style="letter-spacing:2px;">Premium Access</span>
          <h2 style="font-family:'Cormorant Garamond',serif;font-size:2.8rem;font-weight:400;color:#1c1917;margin-top:1rem;">The Mayim Masterclass</h2>
        </div>
        <div class="row justify-content-center">
          <div class="col-lg-10">
            <div class="bg-white d-flex flex-column flex-md-row" style="border-radius:1rem;box-shadow:0 8px 40px rgba(0,0,0,0.1);border:1px solid rgba(217,119,6,0.2);overflow:hidden;">
              <!-- Left -->
              <div class="p-5 col-md-5 d-flex flex-column justify-content-center text-center" style="background:linear-gradient(135deg,rgba(250,248,245,0.7) 0%,rgba(217,119,6,0.05) 100%);">
                <h3 class="fw-normal mb-4 text-dark text-uppercase" style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;letter-spacing:1px;">Lifetime Ticket</h3>
                <div class="mb-4">
                  <span class="text-muted d-block mb-2" style="text-decoration:line-through;">Was $29</span>
                  <span class="px-3 py-1 small fw-bold text-uppercase" style="background:#d97706;color:#fff;letter-spacing:1px;border-radius:3px;">Launch Offer</span>
                </div>
                <div class="d-flex justify-content-center align-items-baseline mb-4" style="line-height:1;">
                  <span class="text-muted fw-bold me-2" style="font-size:1.25rem;">USD</span>
                  <span style="font-family:'Cormorant Garamond',serif;font-size:5.5rem;letter-spacing:-3px;font-weight:300;color:#1c1917;">19</span>
                </div>
                <a href="#" class="btn-amber-en d-block py-3 text-center" style="font-size:1rem;">Enroll Now &nbsp;→</a>
                <div class="mt-4 pt-3 d-flex flex-column align-items-center gap-2" style="border-top:1px solid rgba(0,0,0,0.06);">
                  <p class="text-muted small text-uppercase mb-0" style="font-size:0.70rem;font-weight:600;">100% Secure &amp; Encrypted</p>
                  <span class="text-muted" style="font-size:0.8rem;opacity:0.5;">🔒 💳 🛡️</span>
                </div>
              </div>
              <!-- Right -->
