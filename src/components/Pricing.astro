---
import pricingData from '../data/pricing.json';
---
<section class="pricing-section py-5 my-3 position-relative z-1" id="checkout">
  <div class="container reveal py-5">
    <div class="text-center mb-5 pb-2">
      <span class="text-accent text-uppercase tracking-wide small fw-bold" style="letter-spacing: 2px;">Acceso Premium</span>
      <h2 class="display-4 text-dark mt-3" style="font-family: 'Cormorant Garamond', serif;">La Masterclass Mayim</h2>
    </div>

    <div class="row justify-content-center">
      <div class="col-lg-10">
        <div class="bg-white rounded-4 shadow-lg overflow-hidden d-flex flex-column flex-md-row" style="border: 1px solid rgba(217, 119, 6, 0.2);">
          
          <!-- Left Column: Price & Value -->
          <div class="p-5 col-md-5 d-flex flex-column justify-content-center text-center" style="background: linear-gradient(135deg, rgba(250,248,245,0.7) 0%, rgba(217,119,6,0.05) 100%);">
            
            <h3 class="fw-normal mb-4 text-dark text-uppercase tracking-wide" style="font-family: 'Cormorant Garamond', serif; font-size: 1.5rem;">Pase de Por Vida</h3>
            
            <div class="mb-4">
              <span class="text-muted text-decoration-line-through d-block mb-2">Antes ${pricingData.originalPrice}</span>
              <span class="d-inline-block px-3 py-1 small fw-bold text-uppercase tracking-wide rounded-1 shadow-sm" style="background-color: #d97706; color: #ffffff; letter-spacing: 1px;">Oferta de Lanzamiento</span>
            </div>
            
            <div class="d-flex justify-content-center align-items-baseline mb-4" style="line-height: 1;">
              <span class="text-muted fw-bold me-2" style="font-size: 1.25rem;">{pricingData.currency}</span>
              <span class="text-dark" style="font-family: 'Cormorant Garamond', serif; font-size: 5.5rem; letter-spacing: -3px; font-weight: 300;">{pricingData.price}</span>
            </div>
            
            <div class="mt-3 mb-2" style="width: 100%;">
              <a href="#" class="btn btn-amber d-block py-3 fs-5 text-uppercase tracking-wide shadow rounded-2" style="color: #ffffff; width: 100% !important;">Inscríbete Ahora &nbsp;→</a>
            </div>
            
            <div class="mt-4 pt-2 border-top border-secondary border-opacity-10 d-flex flex-column align-items-center gap-2">
              <p class="text-muted small tracking-wide text-uppercase mb-0" style="font-size: 0.70rem; font-weight: 600;">100% Seguro y Encriptado</p>
              <span class="text-muted opacity-50" style="font-size: 0.8rem;">🔒 💳 🛡️</span>
            </div>
            
          </div>
          
          <!-- Right Column: Features List -->
          <div class="p-5 col-md-7 d-flex flex-column justify-content-center border-start py-5">
            <h5 class="text-dark mb-4 text-uppercase tracking-wide pb-3 border-bottom border-opacity-10" style="font-size: 0.9rem;">Qué Incluye tu Pase:</h5>
            <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
              {pricingData.features.map(feature => (
                 <li class="d-flex align-items-start">
                   <span class="text-accent me-3 mt-1" style="font-size: 1.2rem;">✓</span>
                   <span class="text-muted fw-light lh-base" style="font-size: 1.05rem;">{feature}</span>
                 </li>
              ))}
            </ul>
          </div>

        </div>
      </div>
    </div>
  </div>
</section>

<style lang="scss">
  @import '../styles/variables.scss';
  
  .btn-amber {
      background: $color-accent;
      color: white;
      font-family: $font-secondary;
      font-weight: 600;
      letter-spacing: 2px;
      border: none;
      transition: $transition-smooth;
      border-radius: 4px;
      
      &:hover {
        background: $color-accent-hover;
        transform: translateY(-2px);
        box-shadow: $shadow-brand;
        color: white;
      }
    }
    
    .border-start {
      @media (max-width: 768px) {
        border-left: none !important;
        border-top: 1px solid rgba(0,0,0,0.05);
      }
    }
</style>
