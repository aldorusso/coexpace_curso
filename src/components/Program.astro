---
const moduleFiles = import.meta.glob('../content/modules/*.md', { eager: true });
const allModules = Object.values(moduleFiles).map((file: any) => ({
  data: file.frontmatter,
  body: file.rawContent ? file.rawContent() : file.default || '',
}));
allModules.sort((a: any, b: any) => a.data.order - b.data.order);
---
<section class="program-section py-5 my-5 position-relative z-1" style="background-color: transparent;">
  <div class="container py-5 reveal">
    <div class="text-center mb-5">
       <span class="text-accent text-uppercase tracking-wide small fw-bold" style="letter-spacing: 2px;">El Plan de Acción</span>
       <h2 class="display-4 text-dark mt-3" style="font-family: 'Cormorant Garamond', serif;">El Método Mayim</h2>
       <div class="mx-auto mt-4 mb-3" style="width: 40px; height: 1px; background-color: #d97706;"></div>
       <p class="text-muted fw-light fs-5">Un camino paso a paso meticulosamente diseñado para tu transformación.</p>
    </div>
    
    <!-- Outer Wrapper for the slider -->
    <div class="slider-wrapper position-relative w-100">
      
      <!-- The scrolling container -->
      <div class="magazine-slider d-flex shadow-sm" id="magazineSlider">
        {allModules.map((moduleItem, index) => (
          <div class="magazine-card bg-white p-5 position-relative d-flex flex-column h-100 border-end">
            <!-- Background large number -->
            <div class="position-absolute opacity-10 text-accent fw-bold user-select-none" style="top: 10px; right: 20px; font-family: 'Cormorant Garamond', serif; font-size: 10rem; line-height: 1; z-index: 0;">0{index + 1}</div>
            
            <div class="position-relative z-1 d-flex flex-column h-100">
              <span class="text-accent text-uppercase tracking-wide small fw-bold mb-3 d-block" style="letter-spacing: 1px;">Módulo {index + 1}</span>
              <h3 class="text-dark fw-normal mb-4" style="font-family: 'Cormorant Garamond', serif; font-size: 2rem; min-height: 4rem;">{moduleItem.data.title}</h3>
              <p class="text-muted fs-6 fw-light mb-4 pb-4 border-bottom border-secondary border-opacity-10 flex-grow-0" style="font-style: italic;">{moduleItem.data.description}</p>
              
              <div class="module-body flex-grow-1 overflow-auto pe-2" style="max-height: 250px;">
                <ul class="list-unstyled mb-0 d-flex flex-column gap-3">
                  {moduleItem.body.split('\n').filter(line => line.trim() !== '').map(line => {
                    const cleanLine = line.replace(/^- /, '');
                    return (
                      <li class="d-flex align-items-start">
                        <span class="text-accent me-2" style="font-size: 0.8rem; margin-top: 5px;">✦</span> 
                        <span class="text-muted fw-light lh-base small">{cleanLine}</span>
                      </li>
                    );
                  })}
                </ul>
              </div>
            </div>
            
          </div>
        ))}
      </div>
      
      <!-- Fade edges for visual cue -->
      <div class="slider-fade right"></div>
      <div class="slider-fade left"></div>
    </div>
    
    <div class="d-flex justify-content-center gap-2 mt-4 position-relative z-1" id="sliderPagination">
      {allModules.map((_, index) => (
         <button class={`slider-dot ${index === 0 ? 'active' : ''}`} data-index={index} aria-label={`Go to slide ${index + 1}`}></button>
      ))}
    </div>
  </div>
</section>

<style lang="scss">
  @import '../styles/variables.scss';
  
  .slider-wrapper {
    position: relative;
    max-width: 1100px;
    margin: 0 auto;
    
    .slider-fade {
      position: absolute;
      top: 0;
      height: 100%;
      width: 50px;
      pointer-events: none;
      z-index: 2;
      
      &.right { right: 0; background: linear-gradient(to right, rgba(250,248,245,0), rgba(250,248,245,1)); }
      &.left { left: 0; background: linear-gradient(to left, rgba(250,248,245,0), rgba(250,248,245,1)); }
    }
  }

  .slider-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background-color: rgba(217,119,6,0.3);
    border: none;
    padding: 0;
    transition: all 0.3s ease;
    
    &.active {
      background-color: #d97706;
      width: 24px;
      border-radius: 4px;
    }
  }

  .magazine-slider {
    overflow-x: auto;
    overflow-y: hidden;
    scroll-snap-type: x mandatory;
    scroll-behavior: smooth;
    -webkit-overflow-scrolling: touch;
    border-radius: 8px;
    
    /* Hide scrollbar for Chrome, Safari and Opera */
    &::-webkit-scrollbar {
      display: none;
    }
    /* Hide scrollbar for IE, Edge and Firefox */
    -ms-overflow-style: none;
    scrollbar-width: none;
  }

  .magazine-card {
    flex: 0 0 450px; /* Fixed width for standard desktop view */
    flex-shrink: 0;
    scroll-snap-align: center;
    border-color: rgba(0,0,0,0.05);
    height: 600px; /* fixed height for magazine feel */
    transition: $transition-smooth;
    
    &:last-child {
      border-right: none !important;
    }
    
    /* Scrollbar for inner content */
    .module-body::-webkit-scrollbar { width: 4px; }
    .module-body::-webkit-scrollbar-track { background: transparent; }
    .module-body::-webkit-scrollbar-thumb { background: rgba(217,119,6,0.3); border-radius: 10px; }
    
    @media (max-width: 768px) {
      flex: 0 0 320px; /* smaller width for mobile */
      height: 550px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const slider = document.getElementById('magazineSlider');
    if (!slider) return;
    
    let isHovering = false;
    let autoScrollInterval;
    
    // Pause on hover so the user can read the module
    slider.addEventListener('mouseenter', () => isHovering = true);
    slider.addEventListener('mouseleave', () => isHovering = false);
    
    slider.addEventListener('touchstart', () => isHovering = true, {passive: true});
    slider.addEventListener('touchend', () => { setTimeout(() => isHovering = false, 2000) }, {passive: true});
    
    // Update pagination dots on scroll
    const dots = document.querySelectorAll('.slider-dot');
    
    slider.addEventListener('scroll', () => {
       const scrollPos = slider.scrollLeft;
       const cardWidth = window.innerWidth <= 768 ? 320 : 450;
       let activeIndex = Math.round(scrollPos / cardWidth);
       
       // Handle edge case where you reach the very end quickly
       if (activeIndex >= dots.length) activeIndex = dots.length - 1;
       
       dots.forEach((dot, idx) => {
         if (idx === activeIndex) {
            dot.classList.add('active');
         } else {
            dot.classList.remove('active');
         }
       });
    });
    
    // Make bullets clickable
    dots.forEach(dot => {
       dot.addEventListener('click', (e) => {
          // Pause auto-scroll briefly when the user interact manually via dots
          isHovering = true;
          setTimeout(() => isHovering = false, 4000);
          
          const index = parseInt((e.target as HTMLElement).dataset.index || '0');
          const cardWidth = window.innerWidth <= 768 ? 320 : 450;
          slider.scrollTo({ left: index * cardWidth, behavior: 'smooth' });
       });
    });
    
    function startAutoScroll() {
      autoScrollInterval = setInterval(() => {
        if (!isHovering) {
          const scrollAmount = window.innerWidth <= 768 ? 320 : 450; 
          
          // If we reach the end, gracefully scroll back to the beginning
          if (slider.scrollLeft >= (slider.scrollWidth - slider.clientWidth - 10)) {
            slider.scrollTo({ left: 0, behavior: 'smooth' });
          } else {
            slider.scrollBy({ left: scrollAmount, behavior: 'smooth' });
          }
        }
      }, 3500);
    }
    
    setTimeout(startAutoScroll, 2000);
  });
</script>
